# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# Path to your Unity projects folder
UNITY_PROJECTS_DIR=C:/Users/your-user/Documents/Unity Projects

# Public base URL when serving via ngrok or reverse proxy (for Claude Web OAuth).
# Example: https://abc123.ngrok-free.app
# Leave blank for local-only access (defaults to http://127.0.0.1:8000)
# PUBLIC_URL=

# Optional: Brave Search API key
# BRAVE_API_KEY=

# Local LLM via Ollama (install from https://ollama.com)
# LOCAL_AI_ENABLED=true            # set to false to disable at startup
# OLLAMA_MODEL=llama3.2            # any model you have pulled: mistral, codellama, phi3, gemma2:2b, etc.
# OLLAMA_BASE_URL=http://localhost:11434  # change if Ollama runs on a different host/port
